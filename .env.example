# Rishi Fabrics production environment checklist

# API
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
SESSION_SECRET=replace-with-a-long-random-secret
CORS_ORIGIN=https://your-rishi-fabrics-web-url.example
WEB_ORIGIN=https://your-rishi-fabrics-web-url.example
SENTRY_DSN=
NODE_ENV=production
PORT=4000

# Web
NEXT_PUBLIC_API_URL=https://your-rishi-fabrics-api-url.example

# Admin issue alert email
ADMIN_ALERT_EMAIL=srijan@example.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=Rishi Fabrics <alerts@rishifabrics.example>

# Private tech-pack file storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=tech-packs
